<Window 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:reimaginedLauncher1="clr-namespace:ReimaginedLauncher.Utilities.ViewModels"
    xmlns:local="clr-namespace:ReimaginedLauncher"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="ReimaginedLauncher.MainWindow"
    x:DataType="reimaginedLauncher1:NexusUserViewModel"
    Title="D2R Reimagined Launcher"
    MinWidth="1180"
    MinHeight="760"
>
    <Window.Styles>
        <materialIcons:MaterialIconStyles />
        <Style Selector="NotificationCard TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
        </Style>
    </Window.Styles>
    <LayoutTransformControl x:Name="RootScaleControl">
        <Grid x:Name="RootGrid"
              ColumnDefinitions="300,*"
              Margin="20"
              ColumnSpacing="18">
            <Border Grid.Column="0"
                    Classes="panel"
                    Padding="20">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                <Border Grid.Row="0"
                        Classes="hero-panel"
                        Padding="16">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,Auto"
                          RowSpacing="10"
                          ColumnSpacing="12">
                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Text="D2R Reimagined"
                                   FontFamily="Georgia"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldTextBrush}" />

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Launcher"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource GoldBrush}" />
                            <TextBlock Classes="muted"
                                       Text="A darker control surface for launching, updating, and safeguarding your install."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Width="72"
                                Height="72"
                                Background="#120809"
                                BorderBrush="#7B2326"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="8"
                                HorizontalAlignment="Right">
                            <Image x:Name="LogoImage"
                                   Stretch="Uniform" />
                        </Border>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="1" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Navigation"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldBrush}"
                               Margin="0,0,0,6" />
                    <ListBox x:Name="NavigationList"
                             Classes="nav-list"
                             SelectionChanged="OnNavigationSelectionChanged">
                        <ListBoxItem x:Name="NewsAnnouncementsNavItem" Tag="NewsAnnouncements" Content="News &amp; Announcements" />
                        <ListBoxItem x:Name="LaunchNavItem" Tag="Launch" Content="Launch" />
                        <ListBoxItem x:Name="UpdateNavItem" Tag="Update" Content="Install/Update" />
                        <ListBoxItem x:Name="BackupsNavItem" Tag="Backups" Content="Backups" />
                        <ListBoxItem x:Name="SettingsNavItem" Tag="Settings" Content="Settings" />
                        <ListBoxItem x:Name="ModTweaksNavItem" Tag="ModTweaks" Content="Mod Tweaks" />
                        <ListBoxItem x:Name="PluginsNavItem" Tag="Plugins" Content="Plugins" />
                    </ListBox>
                </DockPanel>

                <StackPanel Grid.Row="2"
                            Spacing="10">
                    <TextBlock x:Name="LauncherVersionTextBlock"
                               Classes="muted"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               ToolTip.Tip="Click to check for a launcher update"
                               PointerPressed="OnLauncherVersionClicked" />
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="*,*"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Website, Kind=OpenInNew, IconPlacement=Right}"
                                Name="WebsiteButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Wiki, Kind=OpenInNew, IconPlacement=Right}"
                                Name="WikiButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Nexus, Kind=OpenInNew, IconPlacement=Right}"
                                Name="NexusButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Discord, Kind=OpenInNew, IconPlacement=Right}"
                                Name="DiscordButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="18">
                <StackPanel Grid.Row="0" Spacing="18">
                    <Border x:Name="UpdateBanner"
                            IsVisible="False"
                            Classes="warning-banner"
                            Padding="20,12">
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <materialIcons:MaterialIcon Kind="Update"
                                                            Foreground="{StaticResource GoldBrush}"
                                                            Width="24"
                                                            Height="24"
                                                            VerticalAlignment="Center" />
                                <TextBlock x:Name="UpdateBannerText"
                                           Text="A new launcher update is ready to install."
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="LauncherRestartButton"
                                    Classes="accent"
                                    Content="Restart &amp; Update"
                                    MinHeight="0"
                                    Height="36"
                                    Padding="16,0"
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="OnLauncherRestartClicked" />
                        </Grid>
                    </Border>

                    <Border Classes="panel"
                            Padding="20,16">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Sanctum Status"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock x:Name="VersionTextBlock"
                                               FontFamily="Georgia"
                                               FontSize="24"
                                               FontWeight="Bold" />
                                    <TextBlock x:Name="UpdateAvailableTextBlock"
                                               FontFamily="Georgia"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource GoldBrush}"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,2"
                                               IsVisible="False" />
                                </StackPanel>
                                <TextBlock Classes="muted"
                                           Text="Use the launcher to keep your install current, backed up, and ready to descend." />
                            </StackPanel>

                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        Spacing="8" 
                                        VerticalAlignment="Center">
                                <Button Classes="link-button" 
                                        Content="{materialIcons:MaterialIconExt Kind=History}" 
                                        ToolTip.Tip="Session Log"
                                        VerticalAlignment="Center">
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedRight">
                                            <Border Width="400" MaxHeight="500" Padding="12">
                                                <Grid RowDefinitions="Auto,*">
                                                    <TextBlock Grid.Row="0" Text="Session Log" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="{StaticResource GoldBrush}"/>
                                                    <ScrollViewer Grid.Row="1">
                                                        <ItemsControl ItemsSource="{Binding SessionLog.Entries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,8">
                                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                                                            <materialIcons:MaterialIcon Grid.Row="0" Grid.Column="0" 
                                                                                                        Kind="{Binding Type, Converter={StaticResource LogTypeToIconConverter}}" 
                                                                                                        Foreground="{Binding Type, Converter={StaticResource LogTypeToBrushConverter}}"
                                                                                                        Width="16" Height="16" Margin="0,2,8,0" VerticalAlignment="Top"/>
                                                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontSize="13"/>
                                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Timestamp, StringFormat=\{0:HH:mm:ss\}}" Classes="muted" FontSize="11" Margin="0,4,0,0"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>

                                <Grid VerticalAlignment="Center">
                                    <Button Classes="accent"
                                            Content="Login with Nexus Mods"
                                            Click="OnNexusLoginClicked"
                                            IsVisible="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanConverter}}"
                                            VerticalAlignment="Center" />
                                    <Button x:Name="UserMenuButton"
                                            Classes="accent"
                                            Content="{Binding Name}"
                                            Click="OnUserMenuClick"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"
                                            IsVisible="{Binding IsLoggedIn}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Logout" Click="OnLogoutClicked"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1"
                        Classes="panel"
                        Padding="24">
                    <ContentControl x:Name="ContentArea"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch" />
                </Border>
            </Grid>
        </Grid>
    </LayoutTransformControl>
    
</Window>
