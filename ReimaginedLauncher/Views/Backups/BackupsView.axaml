<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utilities="clr-namespace:ReimaginedLauncher.Utilities"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="520"
             x:CompileBindings="False"
             x:Class="ReimaginedLauncher.Views.Backups.BackupsView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
            <Border x:Name="LoadingBanner"
                    Classes="panel"
                    Padding="16"
                    IsVisible="False">
                <StackPanel Spacing="10">
                    <TextBlock Text="Loading backups..."
                               FontWeight="SemiBold"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="8"/>
                    <TextBlock Classes="muted"
                               Text="Reading backup settings and saved snapshots."/>
                </StackPanel>
            </Border>

            <Grid x:Name="ContentGrid"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto"
                  RowSpacing="12"
                  ColumnSpacing="12">
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
                <TextBlock Classes="view-title" Text="Backups"/>
                <TextBlock Classes="muted" Text="Configure the backup system, choose how often backups run, and restore any saved snapshot."/>
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Classes="panel"
                    Padding="18">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="14">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Save Directory"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="SaveDirectoryTextBox" LostFocus="OnSaveDirectoryChanged"/>
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="1"
                            x:Name="SaveDirectoryBrowseButton"
                            Content="Browse"
                            VerticalAlignment="Bottom"
                            Click="OnSaveDirectoryClick"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Backup Directory"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="BackupDirectoryTextBox" IsReadOnly="True"/>
                    </StackPanel>
                    <Button Grid.Row="1" Grid.Column="1"
                            Content="Browse"
                            VerticalAlignment="Bottom"
                            Click="OnBackupDirectoryClick"/>

                    <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="3*,*,*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                            <CheckBox x:Name="AutomaticBackupsCheckBox"
                                      Content="Enable automatic backup system"
                                      IsCheckedChanged="OnAutomaticBackupsChanged"/>
                            <TextBlock Classes="muted"
                                       Text="When enabled, the launcher runs backups using the interval and retention settings, including a backup before launch. Uncheck this to disable all automatic backups."
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Interval (minutes)"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="BackupIntervalTextBox" PlaceholderText="60" LostFocus="OnBackupConfigurationChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Backup Amount"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="BackupAmountTextBox" PlaceholderText="10" LostFocus="OnBackupConfigurationChanged"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Take Backup Now" Click="OnTakeBackupNowClick"/>
                <Button Content="Restore Selected" Click="OnRestoreSelectedClick"/>
                <Button Content="Select Zip"
                        ToolTip.Tip="Restore from a .zip backup outside the backup folder."
                        Click="OnRestoreFromZipClick"/>
                <Button Content="Refresh" Click="OnRefreshClick"/>
            </StackPanel>

            <Border Grid.Row="3" Grid.ColumnSpan="2" Classes="panel" Padding="12">
                <ListBox x:Name="BackupsListBox"
                         MinHeight="260"
                         MaxHeight="360"
                         SelectionChanged="OnBackupSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="utilities:BackupEntry">
                            <StackPanel Spacing="2" Margin="0,4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Summary}" Opacity="0.75"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="4"
                       Grid.ColumnSpan="2"
                       x:Name="RestoreSelectionTextBlock"
                       Opacity="0.75"
                       Text="Select a backup to restore."/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
