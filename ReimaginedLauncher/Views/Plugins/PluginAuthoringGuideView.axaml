<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReimaginedLauncher.Views.Plugins.PluginAuthoringGuideView">
    <UserControl.Styles>
        <Style Selector="TextBlock.sub-title">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,4,0,2" />
        </Style>
        <Style Selector="TextBlock.bullet">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="14,0,0,0" />
        </Style>
        <Style Selector="TextBlock.lead">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Styles>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="view-title"
                               Text="How To Write a Plugin" />
                    <TextBlock Classes="muted"
                               Text="Package a launcher plugin, declare parameters, and write supported JSON operations." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="OpenWikiButton"
                            Content="Open Full Wiki Guide"
                            Click="OnOpenWikiClicked" />
                    <Button Content="Back to Plugins"
                            Click="OnBackToPluginsClicked" />
                </StackPanel>
            </Grid>

            <!-- Quick links / overview -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="At a Glance" />
                    <TextBlock Classes="lead"
                               Text="A plugin is a .zip archive that bundles a plugininfo.json manifest and one or more operation files. When enabled, the launcher applies those operations to game data before launch." />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Manifest: plugininfo.json (name, version, modVersion, files)." />
                        <TextBlock Classes="bullet" Text="•  Excel edits: any base-folder .txt file except itemstatcost.txt." />
                        <TextBlock Classes="bullet" Text="•  String edits: .json files under data/local/lng/strings." />
                        <TextBlock Classes="bullet" Text="•  Missiles &amp; Monsters edits: data/hd/missiles/missiles.json and data/hd/character/monsters.json (shared flat layout; replace existing keys or addRow new ones)." />
                    </StackPanel>
                    <TextBlock Classes="muted"
                               TextWrapping="Wrap"
                               Text="The complete, up-to-date guide — with a per-file identification table and worked examples — lives on the project wiki. Click &quot;Open Full Wiki Guide&quot; above to open it in your browser." />
                </StackPanel>
            </Border>

            <!-- Folder layout -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="1. Required Folder Layout" />
                    <TextBlock Classes="lead"
                               Text="The archive can contain folders, but it must include exactly one plugininfo.json at any level." />
                    <TextBox x:Name="FolderLayoutTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="92" />
                </StackPanel>
            </Border>

            <!-- Manifest -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="2. plugininfo.json" />

                    <TextBlock Classes="sub-title" Text="Required fields" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  name — display name of your plugin." />
                        <TextBlock Classes="bullet" Text="•  version — your plugin's own version string." />
                        <TextBlock Classes="bullet" Text="•  modVersion — the D2R Reimagined mod version you target, in #.#.# format (e.g. 3.0.7)." />
                        <TextBlock Classes="bullet" Text="•  files — at least one path to a plugin JSON operation file inside the archive." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Optional fields" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  author, description." />
                        <TextBlock Classes="bullet" Text="•  parameters — each parameter requires key, name, and defaultValue. An optional 'type' field selects the editor: missing or 'text' renders as a textbox; 'checkbox' renders as a checkbox and persists 'true'/'false'. An optional 'group' field renders parameters under a section heading on the Plugins page; groups are display-only and never affect parameter lookup, conditions, saving, or apply." />
                        <TextBlock Classes="bullet" Text="•  assets — list of {source, target} entries that copy raw files into the mod folder. Sources must live under the plugin's assets/ folder; targets are paths relative to the mod root (e.g. data/hd/global/sfx/...). Each entry may declare an optional 'condition' that gates the copy." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Asset copies" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  Asset copies are applied last, after every operation, and overwrite any existing file at the target path." />
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  Warning: This plugin directly copies an asset into the mod without reading the mods data, it may cause problems if it is not setup correctly." />
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  Animation pair safety net: data/global/animdata.d2 and data/global/exanimdata.d2 are read together by the game, so if your plugin only copies one of the two the launcher automatically copies that same file onto the other path so they stay in sync. Ship both files yourself if you actually want them to differ." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Example" />
                    <TextBox x:Name="PluginInfoExampleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="260" />
                </StackPanel>
            </Border>

            <!-- Operations -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="3. Plugin JSON Operations" />
                    <TextBlock Classes="lead"
                               Text="Each plugin JSON file is either a single operation object or an array of them." />

                    <TextBlock Classes="sub-title" Text="Excel (.txt) targets" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  All base-folder .txt files are supported except itemstatcost.txt." />
                        <TextBlock Classes="bullet" Text="•  Most files match rows by a unique column (e.g. Skill in skills.txt, Id in monstats.txt)." />
                        <TextBlock Classes="bullet" Text="•  Files whose identifier column contains duplicates use a 0-based numeric row ID instead (e.g. magicprefix.txt, cubemain.txt, hireling.txt)." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="String (.json) targets" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Used for files under data/local/lng/strings (e.g. item-runes.json)." />
                        <TextBlock Classes="bullet" Text="•  Flat d2rr-style layout: file, Key, plus one or more language fields." />
                        <TextBlock Classes="bullet" Text="•  Supported languages: enUS, zhTW, deDE, esES, frFR, itIT, koKR, plPL, esMX, jaJP, ptBR, ruRU, zhCN." />
                        <TextBlock Classes="bullet" Text="•  Only the language fields listed on an entry are overwritten; other languages and other entries are untouched. Unknown fields are ignored." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Missiles &amp; Monsters JSON targets" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Used for the single missiles.json (data/hd/missiles/missiles.json) and monsters.json (data/hd/character/monsters.json) files, both resolved automatically from the mod data root." />
                        <TextBlock Classes="bullet" Text="•  Shared flat layout: file, Key, and a value supplied via updatedValue or parameterKey. No rowIdentifier or column fields." />
                        <TextBlock Classes="bullet" Text="•  operation defaults to replace (the Key must already exist). Use addRow to append a brand-new key/value pair while preserving existing JSON formatting." />
                        <TextBlock Classes="bullet" Text="•  updatedValue supports {{parameter:key}} tokens just like excel operations." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Example" />
                    <TextBox x:Name="OperationsExampleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="360" />
                </StackPanel>
            </Border>

            <!-- Fields -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="4. Available Fields" />

                    <TextBlock Classes="sub-title" Text="Common" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  file (required) — any base-folder .txt except itemstatcost.txt, any .json under data/local/lng/strings, missiles.json, or monsters.json." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Excel (.txt) — row matching" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  rowIdentifier (required) — value from the identifier column, or numeric row ID for files with duplicate identifiers." />
                        <TextBlock Classes="bullet"
                                   Text="•  rowIdentifier range — also accepts &quot;start-end&quot; (inclusive, 0-based) to target many rows at once, e.g. &quot;50-100&quot; on automap.txt or &quot;300-400&quot; on skills.txt. Ranges target rows by data-row index on any supported .txt file." />
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  rowIdentifier object — also accepts an object that overrides the default match logic by listing one or more {column: expectedValue} pairs (e.g. {&quot;Name&quot;: &quot;Skeleton&quot;, &quot;hcIdx&quot;: &quot;86&quot;}). The row must satisfy every pair. On files with duplicate identifier values (rowID files) you should list at least two columns; the launcher emits a warning otherwise so the intended row stays uniquely matched." />
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  rowIdentifier array (updateRow only) — also accepts an array whose elements are any mix of strings, numbers, ranges, and objects. The launcher matches rows for each element in turn and unions the results, so one operation can update several rows at once. Each string element follows the same rules as a single string rowIdentifier (identifier value, numeric row ID, or &quot;start-end&quot; range). Each object element keeps the multi-column AND check, so {&quot;Class&quot;: &quot;skeleton&quot;, &quot;Level&quot;: &quot;5&quot;} only matches rows where every listed column matches. Duplicate matches are de-duplicated. addRow, cloneRow, and swapRow only target one row at a time and reject the array form." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Excel (.txt) — columns" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  column (required unless 'columns' is provided) — a column name on the target file." />
                        <TextBlock Classes="bullet" Text="•  columns (optional) — an array of {column, updatedValue, parameterKey, operation} objects to update multiple columns on the same row(s) with a single rowIdentifier. Each entry inherits operation/updatedValue/parameterKey from the parent operation when omitted." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Excel (.txt) — operation &amp; values" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  operation (optional) — replace (default), multiplyExisting, addExisting, subtractExisting, divideExisting, append, addRow, cloneRow, or swapRow." />
                        <TextBlock Classes="bullet" Text="•  updatedValue — the replacement value; the multiplier for multiplyExisting; the number to add, subtract, or divide by for addExisting / subtractExisting / divideExisting; or the text appended for append." />
                        <TextBlock Classes="bullet" Text="•  parameterKey (optional) — references a parameter declared in plugininfo.json." />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Margin="14,2,0,0"
                                   Text="append wraps the existing value in parentheses and concatenates your entry, e.g. (existingValue)+10*20." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Excel (.txt) — addRow, cloneRow &amp; swapRow" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  sourceRowIdentifier (cloneRow only) — the row to copy from; numeric 0-based index or default rowIdentifier column value." />
                        <TextBlock Classes="bullet" Text="•  mode (cloneRow only) — 'add' (default) appends the cloned row to the end of the file (rowIdentifier must be omitted); 'replace' overwrites the row at rowIdentifier." />
                        <TextBlock Classes="bullet" Text="•  swapRowIdentifier (swapRow only) — the second row to exchange with rowIdentifier." />
                        <TextBlock Classes="bullet" Text="•  swapColumns (swapRow only, optional) — same shape as 'columns'; applied to the row that ends up at swapRowIdentifier after the swap." />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Margin="14,2,0,0"
                                   Text="addRow creates a brand new row at the end of the file (omit rowIdentifier) or inserts it at a 0-based index (rowIdentifier: \&quot;5\&quot;). Provide the new column values via 'columns' (preferred) or 'column'/'updatedValue'. Columns you do not list keep their default value." />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Margin="14,2,0,0"
                                   Text="cloneRow copies an existing row identified by sourceRowIdentifier (numeric 0-based index, or value of the default rowIdentifier column). mode: 'add' (default) always appends the clone to the end of the file — insertion at a specific index is not supported, so omit rowIdentifier. mode: 'replace' overwrites the row at rowIdentifier. Optional 'columns' apply column overrides on top of the clone using the standard replace / append / multiplyExisting / addExisting / subtractExisting / divideExisting operators." />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Margin="14,2,0,0"
                                   Text="swapRow exchanges the rows at rowIdentifier and swapRowIdentifier (each a numeric 0-based index or default rowIdentifier value). Optional 'columns' update the row that ends up at rowIdentifier; optional 'swapColumns' update the row that ends up at swapRowIdentifier — both run after the swap." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="String (.json) operations" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Key (required) — matches the D2R entry's Key." />
                        <TextBlock Classes="bullet" Text="•  Any of the 13 language codes alongside Key with the replacement string. Only the listed language fields on the matched entry are overwritten." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Missiles &amp; Monsters JSON operations" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Key (required) — the missile/monster key inside missiles.json or monsters.json to update or add." />
                        <TextBlock Classes="bullet" Text="•  updatedValue or parameterKey (required) — a single entry name (e.g. safe_arrow for missiles, fallen1 for monsters), not a file path. Both forms expand {{parameter:key}} tokens." />
                        <TextBlock Classes="bullet" Text="•  operation (optional) — replace (default) requires the key to already exist; addRow appends a new key/value pair while preserving existing JSON formatting. No other operations are accepted." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Parameter tokens -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="5. Parameter Tokens" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  updatedValue supports inline tokens of the form {{parameter:key}}." />
                        <TextBlock Classes="bullet" Text="•  Example: set updatedValue to {{parameter:damageMultiplier}} to resolve the value from plugininfo.json at runtime." />
                        <TextBlock Classes="bullet" Text="•  Tokens are not resolved inside string JSON language values — provide the final replacement text directly there." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Optional types & conditions -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="6. Optional Parameter Types &amp; Conditions" />
                    <TextBlock Classes="lead"
                               Text="Plugin authors can opt into checkbox-style parameters and gate individual operations or asset copies behind a small declarative JSON condition. Existing plugins without 'type' or 'condition' continue to behave exactly as before." />

                    <TextBlock Classes="sub-title" Text="Parameter types" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Missing or 'text' — existing behavior. Rendered as a textbox." />
                        <TextBlock Classes="bullet" Text="•  'checkbox' — rendered as a checkbox/switch. The launcher normalizes the persisted value to 'true' or 'false' (case-insensitive aliases such as 1/0/yes/no/on/off/checked are accepted on read)." />
                        <TextBlock Classes="bullet" Text="•  Existing parameterKey and {{parameter:key}} substitution behavior is unchanged for both kinds." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Parameter groups (display only)" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Add an optional 'group' string to any parameter to render it under a section heading on the Plugins page." />
                        <TextBlock Classes="bullet" Text="•  Groups appear in the order they first occur in the parameters array; parameter order within a group is preserved." />
                        <TextBlock Classes="bullet" Text="•  Missing/empty 'group' means the parameter is ungrouped. If no parameter declares a group, the existing flat layout is used." />
                        <TextBlock Classes="bullet" Text="•  Grouping is purely visual: it never affects parameterKey lookup, {{parameter:key}} substitution, condition evaluation, saving, or apply." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Conditions on operations and assets" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Any operation entry inside a plugin JSON file or any asset entry in plugininfo.json may include an optional 'condition' object." />
                        <TextBlock Classes="bullet" Text="•  Missing condition means the operation/asset always applies (existing behavior)." />
                        <TextBlock Classes="bullet" Text="•  Conditions are pure declarative JSON — no scripts or expressions are executed." />
                        <TextBlock Classes="bullet" Text="•  Comparisons run against the effective parameter value: parameter.value if present, otherwise parameter.defaultValue. Boolean-like comparisons are case-insensitive." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Supported condition shapes" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  { &quot;parameterKey&quot;: &quot;someKey&quot;, &quot;equals&quot;: &quot;true&quot; }" />
                        <TextBlock Classes="bullet" Text="•  { &quot;parameterKey&quot;: &quot;someKey&quot;, &quot;notEquals&quot;: &quot;true&quot; }" />
                        <TextBlock Classes="bullet" Text="•  { &quot;all&quot;: [ ...conditions ] } — every nested condition must be true." />
                        <TextBlock Classes="bullet" Text="•  { &quot;any&quot;: [ ...conditions ] } — at least one nested condition must be true." />
                        <TextBlock Classes="bullet" Text="•  { &quot;not&quot;: { ...condition } } — inverts the nested condition." />
                        <TextBlock Classes="bullet" Text="•  Unknown parameterKey or malformed condition shapes produce a clear plugin validation error." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Example" />
                    <TextBox x:Name="ConditionsExampleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="360" />
                </StackPanel>
            </Border>

            <!-- Validation -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="7. Validation Rules" />

                    <TextBlock Classes="sub-title" Text="Manifest &amp; paths" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  File paths must be relative and stay inside the plugin folder; absolute or traversing paths are rejected." />
                        <TextBlock Classes="bullet" Text="•  plugininfo.json must list files that actually exist in the archive." />
                        <TextBlock Classes="bullet" Text="•  modVersion is required and must be in #.#.# format (e.g. 3.0.7) or the plugin is rejected." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Numeric &amp; append operations" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  multiplyExisting, addExisting, subtractExisting, and divideExisting only work on numeric columns and each requires either parameterKey or updatedValue. divideExisting rejects an operand of zero." />
                        <TextBlock Classes="bullet" Text="•  append works on any column type and requires either parameterKey or updatedValue." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="addRow / cloneRow / swapRow" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  addRow rowIdentifier must be empty (append) or a numeric 0-based index in the range 0..rowCount; non-numeric identifiers are rejected." />
                        <TextBlock Classes="bullet" Text="•  cloneRow requires sourceRowIdentifier; mode='add' must omit rowIdentifier (the clone is always appended to the end); mode='replace' requires rowIdentifier. The clone is a deep copy of the source row, then 'columns' overrides apply on top." />
                        <TextBlock Classes="bullet" Text="•  swapRow requires both rowIdentifier and swapRowIdentifier and rejects swapping a row with itself; 'columns' apply post-swap to the row at rowIdentifier, 'swapColumns' to the row at swapRowIdentifier." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="rowIdentifier &amp; columns" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet"
                                   TextWrapping="Wrap"
                                   Text="•  rowIdentifier array elements are validated like the single-value forms: object elements must list real columns (with the same two-columns-on-rowID-files warning), and string elements on rowID files must be a numeric row ID or a &quot;start-end&quot; range. Empty array elements and arrays attached to addRow / cloneRow / swapRow are rejected." />
                        <TextBlock Classes="bullet" Text="•  When using 'columns', each entry must reference a known target column; per-column parameterKey/updatedValue overrides the parent operation's values." />
                        <TextBlock Classes="bullet" Text="•  Unknown parameters and unknown target columns are reported as plugin errors." />
                    </StackPanel>

                    <TextBlock Classes="sub-title" Text="Missiles &amp; Monsters JSON" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  missiles.json and monsters.json entries must include a Key and either updatedValue or parameterKey, and only support the replace (default) and addRow operations." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sharing -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="8. Sharing on GitHub Discussions" />
                    <TextBlock Classes="lead"
                               Text="The launcher's User Plugins page scrapes the Plugins discussion category on GitHub. Your post body must include these fields:" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  Title: Your Plugin Name — shown as the plugin title." />
                        <TextBlock Classes="bullet" Text="•  Desc: or Description: — short summary shown under the title." />
                        <TextBlock Classes="bullet" Text="•  Mod:, ModVer: or ModVersion: followed by a version in #.#.# format — shown beside the title. Posts without a valid mod version are skipped." />
                        <TextBlock Classes="bullet" Text="•  Attach a .zip of your plugin to the post. Posts without a .zip attachment are skipped." />
                    </StackPanel>
                    <TextBlock Classes="muted"
                               TextWrapping="Wrap"
                               Text="The .zip must still contain a valid plugininfo.json with all required fields (name, version, modVersion, files). The launcher validates the archive on install." />
                </StackPanel>
            </Border>

            <!-- Limits -->
            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="9. Current Limits" />
                    <StackPanel Spacing="2">
                        <TextBlock Classes="bullet" Text="•  All base-folder .txt files are supported except itemstatcost.txt." />
                        <TextBlock Classes="bullet" Text="•  Matching is by unique identifier column, or by numeric row ID for files with duplicates." />
                        <TextBlock Classes="bullet" Text="•  Supported operations: replace, multiplyExisting, addExisting, subtractExisting, divideExisting, append, addRow, cloneRow, swapRow." />
                        <TextBlock Classes="bullet" Text="•  A single operation can update multiple columns on the matched row(s) via the 'columns' array." />
                        <TextBlock Classes="bullet" Text="•  Most files use typed parsers from the D2RReimaginedTools library for column validation and data integrity." />
                        <TextBlock Classes="bullet" Text="•  In addition to excel and strings files, the launcher supports edits to data/hd/missiles/missiles.json and data/hd/character/monsters.json via replace (default) and addRow, using the shared {file, Key, updatedValue|parameterKey, [operation]} shape." />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
