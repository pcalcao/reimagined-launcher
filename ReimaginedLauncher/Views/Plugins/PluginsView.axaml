<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:plugins="clr-namespace:ReimaginedLauncher.Utilities"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="560"
             x:Class="ReimaginedLauncher.Views.Plugins.PluginsView">
    <ScrollViewer x:Name="RootScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalAlignment="Stretch"
                  Focusable="True"
                  PointerPressed="OnBackgroundPointerPressed">
        <StackPanel Spacing="18"
                    HorizontalAlignment="Stretch">
            <Border x:Name="LoadingBanner"
                    Classes="panel"
                    Padding="16"
                    HorizontalAlignment="Stretch"
                    IsVisible="False">
                <StackPanel Spacing="10">
                    <TextBlock Text="Loading plugins..."
                               FontWeight="SemiBold" />
                    <ProgressBar IsIndeterminate="True"
                                 Height="8" />
                    <TextBlock Classes="muted"
                               Text="Loading installed plugins and editor state." />
                </StackPanel>
            </Border>

            <StackPanel x:Name="ContentPanel"
                        Spacing="18"
                        HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Classes="view-title"
                           Text="Plugins" />
                <TextBlock Classes="muted"
                           Text="Import zip-based plugins, control execution order, and edit the JSON files that drive launcher-side patching." />
            </StackPanel>

            <Border Classes="panel"
                    Padding="20"
                    HorizontalAlignment="Stretch">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="12">
                    <StackPanel Grid.Row="0"
                                Spacing="4">
                        <TextBlock Classes="section-title"
                                   Text="Installed Plugins" />
                        <TextBlock x:Name="PluginsSummaryTextBlock"
                                   Classes="muted"
                                   Text="Plugins you install appear here. Enable them to apply their JSON changes before launch." />
                    </StackPanel>

                    <WrapPanel Grid.Row="1"
                               Orientation="Horizontal"
                               HorizontalAlignment="Left"
                               ItemSpacing="12"
                               LineSpacing="12">
                        <Button Content="Install Official Plugins"
                                Click="OnOpenOfficialPluginsClicked" />
                        <Button Content="User Plugins"
                                Click="OnOpenUserPluginsClicked" />
                        <Button Content="How To Write a Plugin"
                                Click="OnOpenAuthoringGuideClicked" />
                        <Button Content="Refresh"
                                Click="OnRefreshClicked" />
                        <Button Classes="accent"
                                Content="Import Plugin Zip"
                                Click="OnImportPluginClicked" />
                    </WrapPanel>

                    <StackPanel x:Name="EmptyStatePanel"
                                Grid.Row="2"
                                Spacing="4"
                                IsVisible="False">
                        <TextBlock Text="No plugins have been installed yet."
                                   FontWeight="SemiBold" />
                        <TextBlock Classes="muted"
                                   Text="Install an official plugin or import a zip that contains plugininfo.json plus one or more plugin JSON files." />
                    </StackPanel>

                    <ItemsControl x:Name="PluginsItemsControl"
                                  HorizontalAlignment="Stretch"
                                  Grid.Row="2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="plugins:PluginCatalogItem">
                                <Border Classes="panel"
                                        Margin="0,0,0,12"
                                        Padding="16"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="12"
                                              RowDefinitions="Auto,Auto"
                                              RowSpacing="12">
                                            <CheckBox Grid.Column="0"
                                                      Grid.Row="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                      Click="OnPluginEnabledClicked" />

                                            <StackPanel Grid.Column="1"
                                                        Grid.Row="0"
                                                        Spacing="3">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Classes="muted"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           IsVisible="{Binding HasDescription}" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="12">
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding Version, StringFormat=Version: {0}}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding ModVersion, StringFormat=Mod: {0}}"
                                                               IsVisible="{Binding HasModVersion}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding Author, StringFormat=Author: {0}}"
                                                               IsVisible="{Binding HasAuthor}" />
                                                </StackPanel>
                                                <TextBlock Classes="muted"
                                                           Text="{Binding Order, StringFormat=Execution order {0}}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Grid.Row="0"
                                                       Foreground="{StaticResource GoldTextBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding StatusText}" />

                                            <WrapPanel Grid.Column="1"
                                                       Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Orientation="Horizontal"
                                                       ItemSpacing="8"
                                                       LineSpacing="8">
                                                <Button Content="Up"
                                                        ToolTip.Tip="Move up one slot. Hold Shift while clicking to jump to the top of the list."
                                                        PointerPressed="OnMovePluginButtonPointerPressed"
                                                        Click="OnMovePluginUpClicked" />
                                                <Button Content="Down"
                                                        ToolTip.Tip="Move down one slot. Hold Shift while clicking to jump to the bottom of the list."
                                                        PointerPressed="OnMovePluginButtonPointerPressed"
                                                        Click="OnMovePluginDownClicked" />
                                                <Button Content="Delete"
                                                        Click="OnDeletePluginClicked" />
                                            </WrapPanel>
                                        </Grid>

                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding HasParameters}">
                                            <ToggleButton HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch"
                                                          IsChecked="{Binding IsParametersExpanded, Mode=TwoWay}">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ParametersToggleText}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1"
                                                               Classes="muted"
                                                               Text="{Binding ParametersActionText}" />
                                                </Grid>
                                            </ToggleButton>

                                            <Border Margin="0,10,0,0"
                                                    Padding="12"
                                                    Classes="panel"
                                                    IsVisible="{Binding IsParametersExpanded}">
                                                <!-- Outer ItemsControl renders parameter groups (display-only). When no parameter
                                                     declares a group, ParameterGroups returns a single bucket with HasHeading=false,
                                                     so the inner ItemsControl renders identically to the legacy flat layout. -->
                                                <ItemsControl ItemsSource="{Binding ParameterGroups}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="plugins:PluginParameterGroup">
                                                            <StackPanel Spacing="6"
                                                                        Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           Margin="0,4,0,2"
                                                                           IsVisible="{Binding HasHeading}" />
                                                                <ItemsControl ItemsSource="{Binding Parameters}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="plugins:PluginParameterItem">
                                                                            <StackPanel Margin="0,0,0,8">
                                                                <!-- Text parameter layout: title/description on top, full-width TextBox + Default badge below. -->
                                                                <StackPanel Spacing="6"
                                                                            IsVisible="{Binding IsTextParameter}">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="SemiBold" />
                                                                        <TextBlock Classes="muted"
                                                                                   Text="{Binding Description}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                    <Grid ColumnDefinitions="*,Auto"
                                                                          ColumnSpacing="12">
                                                                        <TextBox Grid.Column="0"
                                                                             Text="{Binding Value, Mode=OneWay}"
                                                                             HorizontalAlignment="Stretch"
                                                                             VerticalAlignment="Center"
                                                                             LostFocus="OnParameterValueChanged" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Classes="muted"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding DefaultValue, StringFormat=Default {0}}" />
                                                                    </Grid>
                                                                </StackPanel>

                                                                <!-- Checkbox parameter layout: compact toggle row with checkbox left, title/description middle, default badge right. -->
                                                                <Border IsVisible="{Binding IsCheckboxParameter}"
                                                                        Padding="8,6"
                                                                        CornerRadius="4">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                                          ColumnSpacing="10"
                                                                          VerticalAlignment="Center">
                                                                        <CheckBox Grid.Column="0"
                                                                                  VerticalAlignment="Center"
                                                                                  IsChecked="{Binding IsChecked, Mode=OneWay}"
                                                                                  IsCheckedChanged="OnParameterCheckedChanged" />
                                                                        <StackPanel Grid.Column="1"
                                                                                    Spacing="2"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       FontWeight="SemiBold"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Classes="muted"
                                                                                       Text="{Binding Description}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Classes="muted"
                                                                                   FontSize="11"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding DefaultValue, StringFormat=Default {0}}" />
                                                                    </Grid>
                                                                </Border>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Plugin JSON Files"
                                                       FontWeight="SemiBold" />

                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="plugins:PluginCatalogFileItem">
                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="12">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding DisplayName}" />
                                                            <Button Grid.Column="1"
                                                                    Content="Edit JSON"
                                                                    Click="OnEditPluginFileClicked" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding Errors}"
                                                      IsVisible="{Binding HasErrors}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border Classes="warning-banner"
                                                            Margin="0,0,0,8"
                                                            Padding="10">
                                                        <TextBlock Text="{Binding .}"
                                                                   TextWrapping="Wrap" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Classes="panel"
                    Padding="20"
                    HorizontalAlignment="Stretch">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="JSON Editor" />
                            <TextBlock x:Name="EditorTitleTextBlock"
                                       Classes="muted"
                                       Text="Select a plugin JSON file to edit it here." />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Classes="warning-banner"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="EditorStatusTextBlock"
                                       Text="No file selected." />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <TextBlock Classes="muted"
                                   Text="Cmd/Ctrl+S saves changes. The editor tracks unsaved changes and only saves when content changed." />
                        <Button x:Name="SaveJsonButton"
                                Grid.Column="1"
                                Classes="accent"
                                Content="Save JSON"
                                Click="OnSaveJsonClicked"
                                IsEnabled="False" />
                    </Grid>
                    <avaloniaEdit:TextEditor x:Name="EditorTextBox"
                                             Classes="code-editor"
                                             MinHeight="420"
                                             MaxHeight="520"
                                             ShowLineNumbers="True"
                                             WordWrap="False"
                                             TextChanged="OnEditorTextChanged"
                                             KeyDown="OnEditorKeyDown" />
                    <TextBlock x:Name="SupportedTargetsTextBlock"
                               Classes="muted"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
